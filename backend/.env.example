# Copy to .env and set values. Do not commit .env to version control.
# Used by: backend (uvicorn / gunicorn). For VPS/Railway set these in the host's env or dashboard.

# MongoDB: Atlas (srv) or local. If Atlas DNS times out (e.g. offline), use local:
# MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/?appName=...
DATABASE_NAME=gym_db

# CORS: comma-separated list of allowed origins (no spaces), e.g. http://localhost:8080,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:8000

# Super admin: single account that can create gym admins. Not stored in DB.
# Use these exact values to sign in from the app -> Super Admin screen.
SUPER_ADMIN_LOGIN_ID=admin@gymsaas.com
SUPER_ADMIN_PASSWORD=Admin@Gym123

# Required in production; use a long random string.
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# --- Optional: Email for password reset and notifications ---
# Option A (recommended in containers e.g. Railway): SendGrid API – no SMTP ports needed.
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# FROM_EMAIL=verified-sender@yourdomain.com
# Option B: SMTP (e.g. GoDaddy, or SendGrid SMTP: smtp.sendgrid.net, port 587 or 2525, username apikey).
# SMTP_SERVER=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_USERNAME=your-email@yourdomain.com
# SMTP_PASSWORD=your-email-password
FROM_EMAIL=your-email@yourdomain.com

# Base URL for reset/registration links (where your app or web is hosted). No trailing slash.
# Users receive emails with links like: FRONTEND_URL/?token=xxx (password reset).
FRONTEND_URL=https://your-app.web.app

# Optional: Firebase Cloud Messaging (mobile push notifications)
# Server key from Firebase project settings -> Cloud Messaging.
# If unset, push notifications are skipped.
# FCM_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
